# Security headers for all routes
# Supported by Netlify (native) and Cloudflare Pages (native).
# Vercel uses vercel.json instead.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://soroban-testnet.stellar.org https://rpc.ankr.com/stellar_soroban https://api.drand.sh https://api2.drand.sh https://api3.drand.sh wss://api.drand.sh; img-src 'self' data:; frame-ancestors 'none'; base-uri 'none'; form-action 'none'
